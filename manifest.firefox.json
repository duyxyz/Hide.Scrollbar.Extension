{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "2.1",
  "description": "__MSG_extDesc__",
  "default_locale": "en",
  "browser_specific_settings": {
    "gecko": {
      "id": "hide-scrollbar-ext@duyxyz",
      "strict_min_version": "109.0"
    }
  },
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "tabs"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon48.png"
    }
  },
  "sidebar_action": {
    "default_panel": "sidepanel.html"
  },
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ]
}
